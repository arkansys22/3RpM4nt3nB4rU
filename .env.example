# Copy this file's variable names into your hosting panel's "Environment
# Variables" feature, or into a gitignored .htaccess via `SetEnv NAME value`.
# Do NOT put real values in this file — it is committed to git.

# Database (application/config/database.php)
DB_HOST=localhost
DB_USER=
DB_PASS=
DB_NAME=

# CodeIgniter environment (index.php) — controls error display & db_debug
CI_ENV=production

# Encryption key for CI's Encryption library (application/config/config.php)
# Generate with: php -r "echo bin2hex(random_bytes(32));"
ENCRYPTION_KEY=

# Explicit base URL (application/config/config.php) — prevents Host header
# injection. Leave unset in local/staging to fall back to auto-detection.
APP_BASE_URL=https://your-production-domain.example/
